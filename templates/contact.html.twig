{% extends 'layout.html.twig' %}

{% block title %}C'Stage - Contact{% endblock %}

{% block main %}
<main>
    <section class="fast-search-section">

        {% if success %}
            <p class="text-primary bold gap-2">Votre message a bien été envoyé !</p>
        {% else %}
                    <h2>Contactez-nous</h2>
            <p class="small-text">Nous sommes là pour vous aider !</p>
            <form method="POST" action="/contact" class="input-field flex-col gap-1">
                <div class="flex-row gap-1">
                    <input type="text" name="name" class="input flex-1" placeholder="Nom">
                    <input type="email" name="email" class="input flex-1" placeholder="Adresse email">
                </div>
                <input type="tel" name="phone" class="input" placeholder="Numéro de téléphone">
                <textarea name="message" class="input" rows="6" placeholder="Commentaire"></textarea>
                <button type="submit" class="btn-primary">Envoyer</button>
            </form>
        {% endif %}
    </section>
</main>
{% endblock %}