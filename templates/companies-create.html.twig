{% extends 'layout.html.twig' %}

{% block main %}
<main class="company-create-page">
    <div class="company-create-wrapper">
        <section class="company-create-card">
            <div class="company-create-header">
                <h1 class="company-create-title">Créer une entreprise</h1>
            </div>

            {% if errors is not empty %}
                <div class="form-errors">
                    {% for error in errors %}
                        <p class="form-error">{{ error }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="POST" action="/entreprises/creation" class="company-create-form">
                <div class="input-field company-field">
                    <label for="name" class="input-label">Nom de l'entreprise</label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="form-control"
                        value="{{ old.name|default('') }}"
                        required
                    >
                </div>

                <div class="input-field company-field">
                    <label for="sector" class="input-label">Secteur</label>
                    <select id="sector" name="sector" class="form-control" required>
                        <option value="">Choisir un secteur</option>
                        <option value="primaire" {{ old.sector|default('') == 'primaire' ? 'selected' : '' }}>Primaire</option>
                        <option value="secondaire" {{ old.sector|default('') == 'secondaire' ? 'selected' : '' }}>Secondaire</option>
                        <option value="tertiaire" {{ old.sector|default('') == 'tertiaire' ? 'selected' : '' }}>Tertiaire</option>
                    </select>
                </div>

                <div class="address-fields">
                    <div class="input-field company-field address-field">
                        <label for="address" class="input-label">Adresse</label>
                        <input
                            type="text"
                            id="address"
                            name="address"
                            class="form-control"
                            value="{{ old.address|default('') }}"
                            placeholder="Ex : 10 rue de la Paix, 75002 Paris"
                            autocomplete="off"
                        >
                        <div id="address-dropdown" class="address-dropdown hidden"></div>
                    </div>

                    <div class="input-field company-field address-field">
                        <label for="country" class="input-label">Pays</label>
                        <input
                            type="text"
                            id="country"
                            name="country"
                            class="form-control"
                            value="{{ old.country|default('') }}"
                            placeholder="Ex : France"
                            autocomplete="off"
                        >
                    </div>
                </div>

                <div class="input-field company-field">
                    <label for="website" class="input-label">Site web</label>
                    <input
                        type="text"
                        id="website"
                        name="website"
                        class="form-control"
                        value="{{ old.website|default('') }}"
                        required
                    >
                </div>

                <div class="input-field company-field">
                    <label for="siret" class="input-label">Numéro de SIRET</label>
                    <input
                        type="text"
                        id="siret"
                        name="siret"
                        class="form-control"
                        value="{{ old.siret|default('') }}"
                        placeholder="Ex : 73282932000074"
                        maxlength="14"
                        pattern="\d{14}"
                        inputmode="numeric"
                    >
                </div>

                <div class="input-field company-field">
                    <label for="description" class="input-label">Description</label>
                    <textarea
                        id="description"
                        name="description"
                        class="form-control company-textarea"
                        placeholder="Présentation de l'entreprise..."
                    >{{ old.description|default('') }}</textarea>
                </div>

                <div class="company-create-actions">
                    <button type="submit" class="btn-primary">Créer l'entreprise</button>
                </div>
            </form>
        </section>
    </div>
</main>
{% endblock %}